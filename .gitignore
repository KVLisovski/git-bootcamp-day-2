# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# --- Секреты и локальные конфиги ---
.env
.env.local
config.local.yaml

# --- Артефакты сборки и зависимости (Python) ---
__pycache__/
*.pyc
.venv/
dist/

# --- Логи ---
*.log
logs/

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Исключение из правила: build/* игнорируем, но build/.gitkeep оставляем.
# Важно: пишем именно build/*, а не build/ — Git не умеет «вытаскивать»
# отдельный файл из полностью исключённого каталога.
build/*
!build/.gitkeep

# --- Только в корне репозитория ---
/notes-private.md

# --- Любая вложенность ---
**/temp
