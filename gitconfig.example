# ===== [user] =====
# Замените на ваши реальные данные
[user]
	name = Your Name
	email = your@email.com
	
# ===== [init] =====
# Автоматически подставлять ветку main при инициализации
[init]
	defaultBranch = main

# ===== [core] =====
# Безопасные настройки для кросс-платформенной работы
[core]
	# Автоматическая нормализация переносов строк (CRLF ↔ LF)
	autocrlf = input
	# Использовать редактор по умолчанию
	editor = nano
	# Подсветка в выводе команд
	color = auto
	# Безопасность: разрешать перемещение репо только доверенным пользователям
	safe.directory = *

# ===== [alias] =====
# Полезные сокращения для повседневной работы
[alias]
	# Краткий статус
	st = status
	# Красивый лог с графом веток
	lg = log --oneline --graph --all --decorate
	# Показать детали последнего коммита
	last = log -1 HEAD --stat
	# Быстрое редактирование глобального конфига
	ec = config --global -e
	
	
